# Server Port (Optional, defaults to 5000)
PORT=5000

# MongoDB Connection URI (Required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/ecochemicals?retryWrites=true&w=majority

# Nodemailer configuration for lead notification emails (Optional)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
OWNER_EMAIL=owner_email@gmail.com

# Admin Authentication Token (Optional, defaults to admin-secret-key)
ADMIN_TOKEN=your_admin_secret_key_here
